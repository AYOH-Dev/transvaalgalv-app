APP_ENV=development
PORT=8083
PUBLIC_BASE_URL=http://localhost:8083
ACCESS_TOKEN_TTL=15m

# Dedicated PostgreSQL development database.
# Use sslmode=require in every environment.
TRANSVAAL_DATABASE_URL=postgres://transvaal_user_dev:change-me@10.100.0.1:5432/transvaalgalv_app_db_dev?sslmode=require
TRANSVAAL_DATABASE_PROXY_URL=postgres://transvaal_user_dev:change-me@127.0.0.1:6543/transvaalgalv_app_db_dev?sslmode=require
DEV_DB_PROXY_TARGET_ADDR=10.100.0.1:5432
DEV_DB_PROXY_LISTEN_ADDR=127.0.0.1:6543

# Minimum 32 characters.
JWT_SECRET=replace-with-a-32-character-minimum-secret

# Optional bootstrap token for creating the first admin account.
# Minimum 32 characters when set.
BOOTSTRAP_ADMIN_TOKEN=replace-with-a-32-character-minimum-bootstrap-token

# DocuWare archive integration.
DOCUWARE_BASE_URL=https://docuware.example.com
DOCUWARE_FILE_CABINET_ID=00000000-0000-0000-0000-000000000000
DOCUWARE_USERNAME=change-me
DOCUWARE_PASSWORD=change-me